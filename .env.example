# Azure OpenAI (default provider)
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1

# OpenAI (alternative)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (alternative)
GOOGLE_API_KEY=your_google_api_key_here

# Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434

# Chainlit Auth
CHAINLIT_AUTH_SECRET="change-this-to-a-random-secret"
CHAINLIT_USER="admin"
CHAINLIT_PASSWORD="admin"

# Debug: print full prompt to stdout before every LLM call
DEBUG_PRINT_PROMPT=false

# Iteration limit — max agent steps before stopping. Increase for large repos.
# Default: 150. The LangGraph recursion_limit is set to 2× this value.
ITERATION_LIMIT=150

# Summarization — triggers when conversation exceeds this many tokens (~75% of context window)
# gpt-4o / gpt-4.1 (128k): 100000  |  gpt-5.3-codex (200k+): 150000
SUMMARIZATION_TOKEN_TRIGGER=100000
SUMMARIZATION_KEEP_MESSAGES=30

# Human-in-the-loop approvals for write operations.
# All default to true — the agent pauses and asks before running these.
# Set to false to allow autonomous operation (e.g. in a trusted CI environment).
REQUIRE_APPROVAL_GIT_COMMIT=true
REQUIRE_APPROVAL_GIT_BRANCH=true
REQUIRE_APPROVAL_GIT_STASH=true
REQUIRE_APPROVAL_EDIT=true
REQUIRE_APPROVAL_EXECUTE=true

# Git authentication
# Type: none (local only) | https_token | https_basic | ssh
GIT_AUTH_TYPE=none

# HTTPS token auth — GitHub PAT, GitLab token, Bitbucket app password
# GIT_TOKEN=ghp_your_personal_access_token_here

# HTTPS basic auth
# GIT_USERNAME=your_username
# GIT_PASSWORD=your_password

# SSH key auth — defaults to ~/.ssh/id_rsa if not set
# GIT_SSH_KEY_PATH=/path/to/your/private_key

# Azure OpenAI (default provider)
AZURE_OPENAI_API_KEY=your_azure_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o

# OpenAI (alternative)
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini (alternative)
GOOGLE_API_KEY=your_google_api_key_here

# Ollama (local, no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434

# Chainlit Auth — CHANGE THESE before deploying to cloud
CHAINLIT_AUTH_SECRET="change-this-to-a-random-secret"
CHAINLIT_USER="admin"
CHAINLIT_PASSWORD="admin"

# Debug: print full prompt to stdout before every LLM call
DEBUG_PRINT_PROMPT=false

# Iteration limit — max agent steps before stopping.
ITERATION_LIMIT=150

# Summarization
SUMMARIZATION_TOKEN_TRIGGER=100000
SUMMARIZATION_KEEP_MESSAGES=30

# Human-in-the-loop approvals (all default to true)
REQUIRE_APPROVAL_GIT_COMMIT=true
REQUIRE_APPROVAL_GIT_BRANCH=true
REQUIRE_APPROVAL_GIT_STASH=true
REQUIRE_APPROVAL_EDIT=true
REQUIRE_APPROVAL_EXECUTE=true

# Git authentication (for local/pre-cloned repos — not used in cloud clone flow)
GIT_AUTH_TYPE=none
# GIT_TOKEN=ghp_your_personal_access_token_here
# GIT_USERNAME=your_username
# GIT_PASSWORD=your_password
# GIT_SSH_KEY_PATH=/path/to/your/private_key

# ─── Cloud / Docker Settings ──────────────────────────────────────────────────

# Path to SQLite database directory.
# In cloud: mount your Azure Files share at this path.
# In Azure Container Apps: set to /app/agent_data and configure the Azure Files volume mount.
AGENT_DATA_DIR=./agent_data

# Base directory for cloned repositories (ephemeral — NOT mounted to Azure storage).
# Each session clones into a subdirectory here; deleted when the session ends.
WORKSPACE_BASE_DIR=./workspaces

# Delete the cloned workspace directory when the session ends.
CLEANUP_WORKSPACE_ON_EXIT=true

# Public base URL — used to generate dashboard links in the review summary.
# Set to your Azure Container Apps URL in cloud deployments.
APP_BASE_URL=http://localhost:8001

# Maximum repository size to clone (MB). Set to 0 to disable.
MAX_CLONE_SIZE_MB=500

# Shallow clone depth. 1 = latest commit only (fast). Set to 0 for full history.
GIT_CLONE_DEPTH=1
